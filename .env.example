# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=hybrid_search006

# JWT
SECRET_KEY=your_secret_key_here_generate_with_openssl_rand_hex_32
ALGORITHM=HS256

# App
INVALID_RESUMES_LOG_PATH=invalid_resumes_log.txt
INVALID_CONTENT_MARKER=Invalid.

# Sentry (optional)
SENTRY_DSN=

# PostgreSQL
DATABASE_URL=postgresql+psycopg2://postgres:postgres@127.0.0.1:5434/resume_rag
